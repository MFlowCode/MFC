    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
    747.6724410272934, &
